# --- Clock (OSC) ---
NET "clk" LOC = "P123" | IOSTANDARD = LVCMOS33; # อ้างอิงจากรูป image_8db4e7.png

# --- K1 Connector (รับสัญญาณจาก ESP32) ---
NET "trigger_in" LOC = "P5"  | IOSTANDARD = LVCMOS33 | PULLDOWN; # K1 Pin 15
NET "reset_n"    LOC = "P46" | IOSTANDARD = LVCMOS33;            # ปุ่ม PB2

# --- K2 Connector (ส่งสัญญาณกลับไป ESP32) ---
NET "s1_to_esp"  LOC = "P6"  | IOSTANDARD = LVCMOS33; # K2 Pin 15
NET "s2_to_esp"  LOC = "P8"  | IOSTANDARD = LVCMOS33; # K2 Pin 13
NET "s3_to_esp"  LOC = "P10" | IOSTANDARD = LVCMOS33; # K2 Pin 11
NET "win_to_esp" LOC = "P12" | IOSTANDARD = LVCMOS33; # K2 Pin 9

# --- LED บนบอร์ด (อ้างอิงจากรูป image_8db4ec.png) ---
# บอร์ดนี้ใช้ P67 ถึง P82 สำหรับ LED L7 ถึง L0
NET "led_s1<0>" LOC = "P82" | IOSTANDARD = LVCMOS33; # L0
NET "led_s1<1>" LOC = "P81" | IOSTANDARD = LVCMOS33; # L1
NET "led_s2<0>" LOC = "P80" | IOSTANDARD = LVCMOS33; # L2
NET "led_s2<1>" LOC = "P79" | IOSTANDARD = LVCMOS33; # L3
NET "led_s3<0>" LOC = "P78" | IOSTANDARD = LVCMOS33; # L4
NET "led_s3<1>" LOC = "P75" | IOSTANDARD = LVCMOS33; # L5
NET "led_s3<2>" LOC = "P74" | IOSTANDARD = LVCMOS33; # L6
NET "win_led"    LOC = "P67" | IOSTANDARD = LVCMOS33; # L7